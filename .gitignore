.env
SUTfolder/
bug_reports/
__pycache__/
*.pyc

# Python / coverage scratch
.coverage
.coverage.*
.hypothesis/
.pytest_cache/

# LLVM coverage profile raw / merged files (should land under
# compares/results/, not the repo root)
*.profraw
*.profdata

# Coverage probe leftovers (SQLite DBs from one-off probes)
test_cov_probe*
test_phase_d_probe

# Config snapshots — tracked in git history, no need to litter root
biotest_config.yaml.backup_*

# Upstream-project NEWS / CHANGELOG copies fetched during research,
# re-fetchable from the upstream repo
biopython_news.rst

# Smoke / scratch dirs
tmp/
evosuite-report/

# Mangled paths from broken Docker mount escapes (Windows host)
/C:Users*

# Tier-2 real-world seeds — fetched via seeds/fetch_real_world.py.
# Hand-crafted Tier-1 seeds (minimal_*, spec_example) remain tracked.
seeds/vcf/real_world_*.vcf
seeds/sam/real_world_*.sam

# Tier-3 synthetic seeds — emitted per Phase D iteration by the LLM
# seed synthesizer (mr_engine/agent/seed_synthesizer.py, Rank 1 lever).
# Regenerated every run; never committed.
seeds/vcf/synthetic_iter*_*.vcf
seeds/sam/synthetic_iter*_*.sam

# Large files exceeding GitHub's 100MB limit
compares/baselines/evosuite/jdk17/jdk17.zip
compares/baselines/evosuite/jdk17/jdk-17.0.13+11/
coverage_artifacts/jacoco/jacoco.exec

# Rust build output
**/target/
**/Cargo.lock.bak

# Jazzer crash reproducer stubs — emitted to cwd on every finding.
# coverage_sampler now pins them to per-rep reproducers/ dirs inside
# compares/results/coverage/**, but ignore any stragglers at repo root.
/Crash_*.java
**/Crash_*.java

# htsjdk classes extracted on demand by coverage_sampler for JaCoCo
# --classfiles; rebuilt from the harness fatjar when missing.
compares/harnesses/jazzer/build/htsjdk-classes/

# Phase-3 scaffolding — compiled Java artefacts + downloaded JUnit
# jars; both are rebuilt on demand by phase3_jazzer_pit.sh.
compares/scripts/phase3_pit/build/
compares/scripts/phase3_pit/lib/
