*.pyc

# Tier-2 real-world seeds — fetched via seeds/fetch_real_world.py.
# Hand-crafted Tier-1 seeds (minimal_*, spec_example) remain tracked.
seeds/vcf/real_world_*.vcf
seeds/sam/real_world_*.sam

# Tier-3 synthetic seeds — emitted per Phase D iteration by the LLM
# seed synthesizer (mr_engine/agent/seed_synthesizer.py, Rank 1 lever).
# Regenerated every run; never committed.
seeds/vcf/synthetic_iter*_*.vcf
seeds/sam/synthetic_iter*_*.sam

