\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Mutation kill rate (\%) per (SUT, format). Each polygon vertex is the per-tool mean kill rate over $n$ replicates ($n$ and the close-margin / deterministic split are listed in \S  \ref {sec:mutation-adequacy}). Every tool is drawn as a closed filled polygon emanating from the centre; \textsc  {BioTest}\xspace  {} (filled blue) covers all six axes, Jazzer forms a filled triangle in the left half, Pure-Random traces a small floor hexagon, and the remaining baselines collapse to thick filled spikes / lines because their geometry has no enclosed area.}}{5}{figure.3}\protected@file@percent }
\newlabel{fig:mutation-radar}{{3}{5}{Mutation kill rate (\%) per (SUT, format). Each polygon vertex is the per-tool mean kill rate over $n$ replicates ($n$ and the close-margin / deterministic split are listed in \S \ref {sec:mutation-adequacy}). Every tool is drawn as a closed filled polygon emanating from the centre; \biotest {} (filled blue) covers all six axes, Jazzer forms a filled triangle in the left half, Pure-Random traces a small floor hexagon, and the remaining baselines collapse to thick filled spikes / lines because their geometry has no enclosed area}{figure.3}{}}
