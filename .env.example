# ─── LLM Configuration ───
# Model identifier (examples: gemini-1.5-pro, gpt-4o, claude-3-5-sonnet-20241022)
LLM_MODEL=gemini-1.5-pro
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# ─── Provider API Keys (set the one matching your LLM_MODEL) ───
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Local vLLM (optional) ───
# Use LLM_MODEL=vllm/<model-name> and set the base URL
VLLM_BASE_URL=http://localhost:8000/v1
