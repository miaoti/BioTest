{
  "enforced": [
    {
      "mr_id": "99d69275e18a",
      "mr_name": "Flag bit 0x4 unmapped contradiction rejection",
      "scope": "SAM.record",
      "preconditions": [
        "has_mapped_read"
      ],
      "transform_steps": [
        "violate_flag_bit_exclusivity"
      ],
      "oracle": "All SUTs must REJECT (raise error/crash) or at minimum tag as invalid; silent acceptance is a conformance bug",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p47",
          "quote": "Bit 0x4 is the only reliable place to tell whether the read is unmapped. If 0x4 is set, no assumptions can be made about RNAME, POS, CIGAR, MAPQ, and bits 0x2, 0x100, and 0x800.",
          "rule_severity": "CRITICAL",
          "section_id": "The SAM Format Specification"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
    {
      "mr_id": "319f95e31472",
      "mr_name": "CIGAR-SEQ length mismatch rejection",
      "scope": "SAM.record",
      "preconditions": [
        "has_cigar",
        "has_seq"
      ],
      "transform_steps": [
        "violate_cigar_seq_length"
      ],
      "oracle": "All SUTs must REJECT (raise error/crash) or at minimum tag as invalid; silent acceptance is a conformance bug",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p53",
          "quote": "SEQ: segment SEQuence. This field can be a `*' when the sequence is not stored. If not a `*', the length of the sequence must equal the sum of lengths of MIS=X operations in CIGAR.",
          "rule_severity": "CRITICAL",
          "section_id": "The SAM Format Specification"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
    {
      "mr_id": "705c9755b48c",
      "mr_name": "TLEN sign consistency violation rejection",
      "scope": "SAM.record",
      "preconditions": [
        "has_nonzero_tlen"
      ],
      "transform_steps": [
        "violate_tlen_sign_consistency"
      ],
      "oracle": "All SUTs must REJECT (raise error/crash) or at minimum tag as invalid; silent acceptance is a conformance bug",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p50",
          "quote": "The TLEN field is positive for the leftmost segment of the template, negative for the rightmost, and the sign for any middle segment is undefined. If segments cover the same coordinates then the choice of which is leftmost and rightmost is arbitrary, but the two ends must still have differing signs.",
          "rule_severity": "CRITICAL",
          "section_id": "The SAM Format Specification"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
    {
      "mr_id": "79d81ed64ecf",
      "mr_name": "Coordinate boundary preservation under header reordering",
      "scope": "SAM.header",
      "preconditions": [
        "has_sq_line"
      ],
      "transform_steps": [
        "reorder_header_records",
        "query_method_roundtrip"
      ],
      "oracle": "Coordinate-related query methods should return identical values after reordering @SQ header lines (reference sequence dictionary order doesn't affect coordinate calculations)",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p30",
          "quote": "[SAM v1 — The SAM Format Specification] Regular expression:  (coordinate|queryname|unsorted)(:[\"A-Za-z0-9_-\"]+)+\\1-3\n2|l @SQ & Reference sequence dictionary.",
          "rule_severity": "CRITICAL",
          "section_id": "The SAM Format Specification"
        },
        {
          "chunk_id": "SAMv1.tex::The header section::p87",
          "quote": "[SAM v1 — The header section] Regular expression:  (coordinate|queryname|unsorted)(:[\"A-Za-z0-9_-\"]+)+\\1-3\n2|l @SQ & Reference sequence dictionary. The order",
          "rule_severity": "CRITICAL",
          "section_id": "The header section"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": [
        "getAlignmentStart",
        "getAlignmentEnd",
