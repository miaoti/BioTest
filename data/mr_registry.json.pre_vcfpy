      "mr_id": "7690cdb23c3e",
      "mr_name": "CIGAR operation split/merge equivalence",
      "scope": "SAM.record",
      "preconditions": [
        "has_cigar"
      ],
      "transform_steps": [
        "split_or_merge_adjacent_cigar_ops"
      ],
      "oracle": "The parsed alignment should represent the same genomic coordinates and query consumption regardless of whether adjacent identical CIGAR operations are merged or split",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::Recommended Practice for the SAM Format::p134",
          "quote": "* Adjacent CIGAR operations should be different.",
          "rule_severity": "ADVISORY",
          "section_id": "Recommended Practice for the SAM Format"
        }
      ],
      "ambiguity_flags": [
        "The spec uses 'should' (ADVISORY) not 'must' (NORMATIVE), so parsers MAY accept adjacent identical operations but SHOULD normalize them"
      ],
      "query_methods": []
    },
