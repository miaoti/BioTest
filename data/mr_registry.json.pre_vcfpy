    {
      "mr_id": "0f61b7b3a065",
      "mr_name": "Coordinate system invariance under SAM-BAM roundtrip",
      "scope": "SAM.record",
      "preconditions": [
        "has_mapped_read"
      ],
      "transform_steps": [
        "sam_bam_round_trip"
      ],
      "oracle": "For mapped reads, POS values should remain identical after SAM→BAM→SAM roundtrip, preserving 1-based coordinate semantics",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p16",
          "quote": "[1-based coordinate system] A coordinate system where the first base of a sequence is one. In this coordinate system, a region is specified by a closed interval. For example, the region between the 3rd and the 7th bases inclusive is $[3,7]$. The SAM, VCF, GFF and Wiggle formats are using the 1-based coordinate system.",
          "rule_severity": "INFORMATIONAL",
          "section_id": "The SAM Format Specification"
        },
        {
          "chunk_id": "SAMv1.tex::Recommended Practice for the SAM Format::p138",
          "quote": "* If POS plus the sum of lengths of M=XDN operations in CIGAR exceeds the length specified in the LN field of the @SQ header line (if exists) with an SN equal to RNAME, the alignment should be unmapped, unless the reference sequence is circular (see below).",
          "rule_severity": "ADVISORY",
          "section_id": "Recommended Practice for the SAM Format"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
