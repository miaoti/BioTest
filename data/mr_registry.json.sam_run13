{
  "enforced": [
    {
      "mr_id": "319f95e31472",
      "mr_name": "CIGAR-SEQ length mismatch rejection",
      "scope": "SAM.record",
      "preconditions": [
        "has_cigar",
        "has_seq"
      ],
      "transform_steps": [
        "violate_cigar_seq_length"
      ],
      "oracle": "Parsers MUST reject (raise error or crash) when CIGAR query-consuming length (M,I,S,=,X) does not equal len(SEQ) and SEQ is not '*'. Silent acceptance or silent record-drop is a conformance bug.",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The alignment section: mandatory fields::p121",
          "quote": "SEQ: segment SEQuence. This field can be a `*' when the sequence is not stored. If not a `*', the length of the sequence must equal the sum of lengths of MIS=X operations in CIGAR.",
          "rule_severity": "CRITICAL",
          "section_id": "The alignment section: mandatory fields"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
    {
      "mr_id": "881ad7269964",
      "mr_name": "cigar_seq_length_consistency_invariance_under_roundtrip",
      "scope": "SAM.record",
      "preconditions": [
        "has_cigar",
        "has_seq"
      ],
      "transform_steps": [
        "sut_write_roundtrip",
        "query_method_roundtrip"
      ],
      "oracle": "P(parse(x)) == P(parse(T(x))) for each listed method: getCigarLength, getCigarString, getReadLength, getAlignmentStart, getAlignmentEnd must be invariant under write-roundtrip since the spec mandates 'Sum of lengths of the MIS=X operations shall equal the length of SEQ'",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The alignment section: mandatory fields::p118",
          "quote": "Sum of lengths of the MIS=X operations shall equal the length of SEQ.",
          "rule_severity": "CRITICAL",
          "section_id": "The alignment section: mandatory fields"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": [
        "getCigarLength",
        "getCigarString",
        "getReadLength",
        "getAlignmentStart",
        "getAlignmentEnd"
      ]
    },
    {
