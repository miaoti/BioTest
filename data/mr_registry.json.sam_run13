    {
      "mr_id": "99d69275e18a",
      "mr_name": "Flag bit 0x4 mapped/unmapped contradiction rejection",
      "scope": "SAM.record",
      "preconditions": [
        "has_mapped_read"
      ],
      "transform_steps": [
        "violate_flag_bit_exclusivity"
      ],
      "oracle": "Parsers MUST reject (raise error or crash) when FLAG bit 0x4 (segment unmapped) is set but RNAME is not '*' and POS is not 0, as this creates a mapped/unmapped contradiction. Silent acceptance or silent record-drop is a conformance bug.",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::Recommended Practice for the SAM Format::p137",
          "quote": "If all segments in a template are unmapped, their RNAME should be set as `*' and POS as 0.",
          "rule_severity": "ADVISORY",
          "section_id": "Recommended Practice for the SAM Format"
        },
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p47",
          "quote": "Bit 0x4 is the only reliable place to tell whether the read is unmapped. If 0x4 is set, no assumptions can be made about RNAME, POS, CIGAR, MAPQ, and bits 0x2, 0x100, and 0x800.",
          "rule_severity": "CRITICAL",
          "section_id": "The SAM Format Specification"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
    {
      "mr_id": "705c9755b48c",
      "mr_name": "TLEN sign consistency rejection for paired reads",
      "scope": "SAM.record",
      "preconditions": [
        "has_nonzero_tlen"
      ],
      "transform_steps": [
        "violate_tlen_sign_consistency"
      ],
      "oracle": "Parsers MUST reject (raise error or crash) when two reads of a paired template carry same-signed TLEN values, violating the opposite-signed pairing convention. Silent acceptance or silent record-drop is a conformance bug.",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The alignment section: mandatory fields::p110",
          "quote": "9 & TLEN & Int & $[-2^31+1,\\,2^31-1]$ & observed Template LENgth",
          "rule_severity": "INFORMATIONAL",
          "section_id": "The alignment section: mandatory fields"
        }
      ],
      "ambiguity_flags": [
        "The exact definition of TLEN is implementation-defined per the spec, but the opposite-signed convention for paired reads is a well-established invariant that parsers should enforce."
      ],
      "query_methods": []
    },
    {
      "mr_id": "21d5c64a8282",
      "mr_name": "unmapped_read_pos_zero_invariance_under_flag_violation",
      "scope": "SAM.record",
      "preconditions": [
        "has_mapped_read"
      ],
      "transform_steps": [
        "violate_flag_bit_exclusivity",
        "query_method_roundtrip"
      ],
      "oracle": "After setting flag 0x4 on a mapped read (violating the spec), a conformant parser should detect the inconsistency. The getReadUnmappedFlag() must return true, but getAlignmentStart() and getReferenceName() may still return the original values since the spec says 'If 0x4 is set, no assumptions can be made about RNAME, POS, CIGAR, MAPQ'",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p47",
          "quote": "POS: 1-based leftmost mapping POSition of the first CIGAR operation that ``consumes'' a reference base (see table below). The first base in a reference sequence has coordinate 1. POS is set as 0 for an unmapped read without coordinate.",
          "rule_severity": "CRITICAL",
          "section_id": "The SAM Format Specification"
        }
      ],
      "ambiguity_flags": [
        "The spec says 'no assumptions can be made' when 0x4 is set, meaning parsers may handle this inconsistently"
      ],
      "query_methods": [
        "getReadUnmappedFlag",
        "getAlignmentStart",
        "getReferenceName"
      ]
    },
