    {
      "mr_id": "d32bc566b4b5",
      "mr_name": "Splitting or merging adjacent identical CIGAR operations preserves alignment semantics",
      "scope": "SAM.record",
      "preconditions": [
        "has_cigar",
        "has_seq"
      ],
      "transform_steps": [
        "split_or_merge_adjacent_cigar_ops",
        "query_method_roundtrip"
      ],
      "oracle": "P(parse(x)) == P(parse(T(x))) for each listed query method; splitting 10M into 4M6M or merging 4M6M into 10M preserves total query-consumed length and alignment coordinates per SAMv1 recommended practice",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::Recommended Practice for the SAM Format::p134",
          "quote": "Adjacent CIGAR operations should be different.",
          "rule_severity": "ADVISORY",
          "section_id": "Recommended Practice for the SAM Format"
        }
      ],
      "ambiguity_flags": [
        "The spec says 'should' (advisory), not 'must' (normative), so adjacent identical CIGAR ops are technically valid but discouraged. Splitting/merging them is semantics-preserving since total consumed length is unchanged."
      ],
      "query_methods": [
        "getReadName",
        "getFlags",
        "getAlignmentStart",
        "getAlignmentEnd",
        "getReadString"
      ]
    },
    {
      "mr_id": "79d81ed64ecf",
      "mr_name": "Reordering @SQ header lines preserves alignment semantics when SO is not coordinate",
      "scope": "SAM.header",
      "preconditions": [
        "has_sq_line"
      ],
      "transform_steps": [
        "reorder_header_records",
        "query_method_roundtrip"
      ],
      "oracle": "P(parse(x)) == P(parse(T(x))) for each listed query method; @SQ line order defines coordinate sort order but does not affect individual record parsing semantics",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p29",
          "quote": "For coordinate sort, the major sort key is the RNAME field, with order defined by the order of @SQ lines in the header.",
          "rule_severity": "CRITICAL",
          "section_id": "The SAM Format Specification"
        }
      ],
      "ambiguity_flags": [
        "If SO:coordinate, reordering @SQ changes the sort semantics; this MR is safest when SO is not coordinate or when testing that individual record parsing is unaffected regardless of sort order."
      ],
      "query_methods": [
        "getReadName",
        "getFlags",
        "getCigarString",
        "getReadString",
        "getMappingQuality"
      ]
    },
    {
      "mr_id": "7690cdb23c3e",
      "mr_name": "CIGAR split/merge normalization invariance",
      "scope": "SAM.record",
      "preconditions": [
        "has_cigar"
      ],
      "transform_steps": [
        "split_or_merge_adjacent_cigar_ops"
      ],
      "oracle": "After splitting or merging adjacent identical CIGAR operations (e.g., 10M ⇌ 4M6M), the total query-consumed length and reference-consumed length remain unchanged; all alignment coordinates (POS, END) and the SEQ/QUAL strings are identical; the parsed alignment's getCigarString() may differ but getAlignmentStart(), getAlignmentEnd(), getReadLength(), and getLengthOnReference() are invariant.",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::Recommended Practice for the SAM Format::p134",
          "quote": "* Adjacent CIGAR operations should be different.",
          "rule_severity": "ADVISORY",
          "section_id": "Recommended Practice for the SAM Format"
        }
      ],
      "ambiguity_flags": [
        "The spec says 'should' (ADVISORY), not 'must' — adjacent identical ops are discouraged but not forbidden; a conformant parser must accept both forms as semantically equivalent."
      ],
      "query_methods": []
    },
    {
      "mr_id": "14be4e2cd78b",
      "mr_name": "Write roundtrip normalization invariance",
      "scope": "SAM.record",
      "preconditions": [
        "primary_sut_has_writer"
      ],
      "transform_steps": [
        "sut_write_roundtrip"
      ],
      "oracle": "Parsing a SAM file with the primary SUT, then re-serializing via its writer API, then re-parsing yields an identical in-memory representation; all alignment records, header metadata, and optional tags are preserved.",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p26",
          "quote": "Within each (non-@CO) header line, no field tag may appear more than once and the order in which the fields appear is not significant.",
          "rule_severity": "ADVISORY",
          "section_id": "The SAM Format Specification"
        },
        {
          "chunk_id": "SAMv1.tex::Recommended Practice for the SAM Format::p134",
          "quote": "* Adjacent CIGAR operations should be different.",
          "rule_severity": "ADVISORY",
          "section_id": "Recommended Practice for the SAM Format"
        }
      ],
      "ambiguity_flags": [
        "The writer may normalize CIGAR operations (e.g., merging adjacent identical ops) or reorder header subtags, which is permissible per spec; the oracle must compare semantic equivalence, not byte-for-byte identity."
      ],
      "query_methods": []
    },
    {
      "mr_id": "fb51ee08fb7d",
      "mr_name": "Optional tag type character rejection",
