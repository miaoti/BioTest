  {
    "section": "The alignment section: mandatory fields",
    "headers": [
      "2cBit",
      "Description"
    ],
    "rows": [
      [
        "1",
        "0x1",
        "template having multiple segments in sequencing"
      ],
      [
        "2",
        "0x2",
