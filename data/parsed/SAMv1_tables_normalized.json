[
  {
    "type": "generic",
    "section": "The alignment section: mandatory fields",
    "headers": [
      "Col",
      "Field",
      "Type",
      "Regexp/Range",
      "Brief description"
    ],
    "records": [
      {
        "Col": "1",
        "Field": "QNAME",
        "Type": "String",
        "Regexp/Range": "",
        "Brief description": "Query template NAME"
      },
      {
        "Col": "2",
        "Field": "FLAG",
        "Type": "Int",
        "Regexp/Range": "[0, 2^16-1]",
        "Brief description": "bitwise FLAG"
      },
      {
        "Col": "3",
        "Field": "RNAME",
        "Type": "String",
        "Regexp/Range": "|",
        "Brief description": "Reference sequence NAME"
      },
      {
        "Col": "4",
        "Field": "POS",
        "Type": "Int",
        "Regexp/Range": "[0, 2^31-1]",
        "Brief description": "1-based leftmost mapping POSition"
      },
      {
        "Col": "5",
        "Field": "MAPQ",
        "Type": "Int",
        "Regexp/Range": "[0, 2^8-1]",
        "Brief description": "MAPping Quality"
      },
      {
        "Col": "6",
        "Field": "CIGAR",
        "Type": "String",
        "Regexp/Range": "92*|([0-9]+[MIDNSHP=X])+",
        "Brief description": "CIGAR string"
      },
      {
        "Col": "7",
        "Field": "RNEXT",
        "Type": "String",
        "Regexp/Range": "|=|",
        "Brief description": "Reference name of the mate/next read"
      },
      {
        "Col": "8",
        "Field": "PNEXT",
        "Type": "Int",
        "Regexp/Range": "[0, 2^31-1]",
        "Brief description": "Position of the mate/next read"
      },
      {
        "Col": "9",
        "Field": "TLEN",
        "Type": "Int",
        "Regexp/Range": "[-2^31+1, 2^31-1]",
        "Brief description": "observed Template LENgth"
      },
      {
        "Col": "10",
        "Field": "SEQ",
        "Type": "String",
        "Regexp/Range": "92*|[A-Za-z=.]+",
        "Brief description": "segment SEQuence"
      },
      {
        "Col": "11",
        "Field": "QUAL",
        "Type": "String",
        "Regexp/Range": "[!-126]+",
        "Brief description": "ASCII of Phred-scaled base QUALity+33"
      }
    ]
  },
  {
    "type": "flag_bits",
    "section": "The alignment section: mandatory fields",
    "headers": [
      "2cBit",
      "Description"
    ],
    "records": []
  },
  {
    "type": "cigar_operations",
    "section": "The alignment section: mandatory fields",
    "headers": [
      "op",
      "bam_code",
      "description",
      "consumes_query",
      "consumes_reference"
    ],
    "records": [
      {
        "op": "M",
        "bam_code": 0,
        "description": "alignment match (can be a sequence match or mismatch)",
        "consumes_query": true,
        "consumes_reference": true
      },
      {
        "op": "I",
        "bam_code": 1,
        "description": "insertion to the reference",
        "consumes_query": true,
        "consumes_reference": false
      },
      {
        "op": "D",
        "bam_code": 2,
        "description": "deletion from the reference",
        "consumes_query": false,
        "consumes_reference": true
      },
      {
        "op": "N",
        "bam_code": 3,
        "description": "skipped region from the reference",
        "consumes_query": false,
        "consumes_reference": true
      },
      {
        "op": "S",
        "bam_code": 4,
        "description": "soft clipping (clipped sequences present in SEQ)",
        "consumes_query": true,
        "consumes_reference": false
      },
      {
        "op": "H",
        "bam_code": 5,
        "description": "hard clipping (clipped sequences NOT present in SEQ)",
        "consumes_query": false,
        "consumes_reference": false
      },
      {
        "op": "P",
        "bam_code": 6,
        "description": "padding (silent deletion from padded reference)",
        "consumes_query": false,
        "consumes_reference": false
      },
      {
        "op": "=",
        "bam_code": 7,
        "description": "sequence match",
        "consumes_query": true,
        "consumes_reference": true
      },
      {
        "op": "X",
        "bam_code": 8,
        "description": "sequence mismatch",
        "consumes_query": true,
        "consumes_reference": true
      }
    ]
  },
  {
    "type": "generic",
    "section": "The alignment section: optional fields",
    "headers": [
      "Type",
      "Regexp matching VALUE",
      "Description"
    ],
    "records": [
      {
        "Type": "A",
        "Regexp matching VALUE": "[!-126]",
        "Description": "Printable character"
      },
      {
        "Type": "i",
        "Regexp matching VALUE": "[-+]?[0-9]+",
        "Description": "Signed integer"
      },
      {
        "Type": "f",
        "Regexp matching VALUE": "[-+]?[0-9]*92.?[0-9]+([eE][-+]?[0-9]+)?",
        "Description": "Single-precision floating number"
      },
      {
        "Type": "Z",
        "Regexp matching VALUE": "[   !-126]*",
        "Description": "Printable string, including space"
      },
      {
        "Type": "H",
        "Regexp matching VALUE": "([0-9A-F][0-9A-F])*",
        "Description": "Byte array in the Hex format"
      },
      {
        "Type": "B",
        "Regexp matching VALUE": "[cCsSiIf](,[-+]?[0-9]*92.?[0-9]+([eE][-+]?[0-9]+)?)*",
        "Description": "Integer or numeric array"
      }
    ]
  },
