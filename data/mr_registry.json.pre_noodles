    {
      "mr_id": "9e3642fe5315",
      "mr_name": "POS_1_based_coordinate_invariance",
      "scope": "VCF.record",
      "preconditions": [
        "has_data_row"
      ],
      "transform_steps": [
        "sut_write_roundtrip"
      ],
      "oracle": "The POS field value must remain unchanged after round-trip parsing and writing, as VCF uses 1-based coordinates where the first base has position 1",
      "evidence": [
        {
          "chunk_id": "VCFv4.5.tex::Fixed fields::p395",
          "quote": "POS — position: The reference position, with the 1st base having position 1.",
          "rule_severity": "CRITICAL",
          "section_id": "Fixed fields"
        },
        {
          "chunk_id": "VCFv4.5.tex::Data lines::p212",
          "quote": "POS — position: The reference position, with the 1st base having position 1.",
          "rule_severity": "CRITICAL",
          "section_id": "Data lines"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    }
