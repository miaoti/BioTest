    },
    {
      "mr_id": "752c1e307098",
      "mr_name": "GT allele indices must not exceed ALT count",
      "scope": "VCF.record",
      "preconditions": [
        "alt_count=1",
        "format_has_gt"
      ],
      "transform_steps": [
        "violate_gt_index_bounds"
      ],
      "oracle": "error_consensus",
      "evidence": [
        {
          "chunk_id": "VCFv4.5.tex::Genotype fields::p448",
          "quote": "LAA\t\t    .\t\t\t    Integer\t    1-based indices into ALT, indicating which alleles are relevant (local) for the current sample",
          "rule_severity": "INFORMATIONAL",
          "section_id": "Genotype fields"
        }
      ],
      "ambiguity_flags": [
        "The spec mentions '1-based indices into ALT' but doesn't explicitly state the upper bound constraint. However, GT indices must reference valid alleles (0 for REF, 1..n for ALT alleles)."
      ],
      "query_methods": []
    },
    {
      "mr_id": "6320bd43d214",
      "mr_name": "BCF binary round-trip invariance",
      "scope": "VCF.record",
      "preconditions": [
        "bcf_codec_available",
        "pysam_runtime_reachable"
      ],
      "transform_steps": [
        "vcf_bcf_round_trip"
      ],
      "oracle": "The canonical content after VCF → BCF → VCF round-trip must be identical to the original canonical content (allowing for BCF-specific encoding of missing values and type information).",
      "evidence": [
