  "quarantine": [
    {
      "mr_id": "31e4b85ca55b",
      "mr_name": "INFO field key-value pair ordering invariance",
      "scope": "VCF.record",
      "preconditions": [
        "info_has_multiple_fields"
      ],
      "transform_steps": [
        "shuffle_info_field_kv"
      ],
      "oracle": "Parsed canonical representation must be identical regardless of semicolon-separated key=value order in INFO column.",
      "evidence": [
        {
          "chunk_id": "VCFv4.5.tex::Fixed fields::p403",
          "quote": "INFO — additional information: Semicolon-separated series of additional information fields, or the MISSING value `.' if none are present.\n  Each subfield consists of a short key with optional values in the format: key[=value[, …,value]].",
          "rule_severity": "ADVISORY",
          "section_id": "Fixed fields"
        }
      ],
      "ambiguity_flags": [
        "The spec does not explicitly state that order is insignificant, but the semicolon-separated format with key=value pairs suggests ordering is not semantically meaningful."
      ],
      "query_methods": []
    },
    {
      "mr_id": "21172f02daed",
      "mr_name": "Multi-allelic split invariance",
      "scope": "VCF.record",
      "preconditions": [
        "alt_count>=2"
      ],
      "transform_steps": [
        "split_multi_allelic"
      ],
      "oracle": "A multi-ALT record split into separate single-ALT records must represent the same variant set; genotype calls and per-ALT INFO fields must be preserved after normalization",
      "evidence": [
        {
          "chunk_id": "VCFv4.5.tex::Fixed fields::p399",
          "quote": "* ALT — alternate base(s): Comma-separated list of alternate non-reference alleles.",
          "rule_severity": "INFORMATIONAL",
          "section_id": "Fixed fields"
        },
        {
          "chunk_id": "VCFv4.5.tex::Data lines::p216",
          "quote": "* ALT — alternate base(s): Comma-separated list of alternate non-reference alleles.",
          "rule_severity": "INFORMATIONAL",
          "section_id": "Data lines"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
    {
      "mr_id": "4af3f36f15b2",
      "mr_name": "Common affix trimming invariance",
      "scope": "VCF.record",
      "preconditions": [
        "alt_count==1",
        "len(REF)>=2 OR len(ALT)>=2",
        "REF[0]==ALT[0] OR REF[-1]==ALT[-1]"
      ],
      "transform_steps": [
        "trim_common_affixes"
      ],
      "oracle": "A variant with shared prefix/suffix bases between REF and ALT, when trimmed to parsimonious form, must represent the same biological variant; parsers that normalize must accept either representation",
      "evidence": [
        {
          "chunk_id": "VCFv4.5.tex::Fixed fields::p397",
          "quote": "For simple insertions and deletions in which either the REF or one of the ALT alleles would otherwise be null/empty, the REF and ALT Strings must include the base before the variant (which must be reflected in the POS field), unless the variant occurs at position 1 on the contig in which case it must include the base after the variant; this padding base is not required (although it is permitted) e.g. for complex substitutions or other variants where all alleles have at least one base represented in their Strings.",
          "rule_severity": "CRITICAL",
          "section_id": "Fixed fields"
        }
      ],
      "ambiguity_flags": [
        "The spec states padding base 'is not required (although it is permitted)', creating ambiguity about canonical representation"
      ],
      "query_methods": []
    },
    {
      "mr_id": "5179a1122537",
      "mr_name": "Homopolymer left-alignment invariance",
      "scope": "VCF.record",
      "preconditions": [
        "alt_count==1",
        "len(REF)!=len(ALT)",
        "REF[0]==REF[-1]",
        "pos>=2"
      ],
      "transform_steps": [
        "left_align_indel"
      ],
      "oracle": "An indel within a homopolymer run, when left-shifted to its canonical position, must represent the same biological variant; parsers compliant with VCF normalization must recognize the equivalent left-shifted form",
      "evidence": [
        {
          "chunk_id": "VCFv4.5.tex::Fixed fields::p397",
          "quote": "For simple insertions and deletions in which either the REF or one of the ALT alleles would otherwise be null/empty, the REF and ALT Strings must include the base before the variant (which must be reflected in the POS field), unless the variant occurs at position 1 on the contig in which case it must include the base after the variant; this padding base is not required (although it is permitted) e.g. for complex substitutions or other variants where all alleles have at least one base represented in their Strings.",
          "rule_severity": "CRITICAL",
          "section_id": "Fixed fields"
        }
      ],
      "ambiguity_flags": [
        "The spec does not explicitly mandate left-alignment but permits multiple representations of the same variant"
      ],
      "query_methods": []
    },
    {
      "mr_id": "978e560983f8",
      "mr_name": "Required fixed columns must be present",
      "scope": "VCF.record",
