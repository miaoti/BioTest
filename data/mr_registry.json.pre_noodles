{
  "enforced": [
    {
      "mr_id": "ffbe4a62d130",
      "mr_name": "Meta-information lines ordering invariance",
      "scope": "VCF.header",
      "preconditions": [
        "has_two_meta_lines"
      ],
      "transform_steps": [
        "shuffle_meta_lines"
      ],
      "oracle": "Parsed canonical representation must be identical regardless of meta-line order (except ##fileformat must stay first).",
      "evidence": [
        {
          "chunk_id": "VCFv4.5.tex::Meta-information lines::p122",
          "quote": "Other than |##fileformat|, they may appear in any order.",
          "rule_severity": "CRITICAL",
          "section_id": "Meta-information lines"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
    {
      "mr_id": "bc124d1e4573",
      "mr_name": "Structured meta-line key-value pair ordering invariance",
      "scope": "VCF.header",
      "preconditions": [
        "header_has_structured_lines"
      ],
      "transform_steps": [
        "permute_structured_kv_order"
      ],
      "oracle": "Parsed canonical representation must be identical regardless of key=value order within ##INFO=<...>, ##FORMAT=<...>, ##FILTER=<...> structured lines.",
      "evidence": [
        {
          "chunk_id": "VCFv4.5.tex::Meta-information lines::p121",
          "quote": "Implementations must not rely on the order of the fields within structured lines and are not required to preserve field ordering.",
          "rule_severity": "CRITICAL",
          "section_id": "Meta-information lines"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
    {
      "mr_id": "2af5800ea12a",
      "mr_name": "ALT permutation with consistent GT and Number=A/R field remapping",
      "scope": "VCF.record",
      "preconditions": [
        "alt_count >= 2",
        "format_has_gt OR header_has_info_number_a OR header_has_info_number_r"
      ],
      "transform_steps": [
        "choose_permutation",
        "permute_ALT",
        "remap_GT",
        "permute_Number_A_R_fields"
      ],
      "oracle": "The transformed VCF must represent the same variant set as the original: all genotype calls, allele-specific annotations (Number=A), and per-allele annotations (Number=R) must be correctly remapped to match the new ALT ordering. The REF allele (index 0) remains unchanged.",
      "evidence": [
        {
          "chunk_id": "VCFv4.5.tex::Information field format::p158",
          "quote": "* R: The field has one value for each possible allele, including the reference.\n  The order of the values must be the reference allele first, then the alternate alleles as listed in the ALT column.",
          "rule_severity": "CRITICAL",
          "section_id": "Information field format"
        },
        {
          "chunk_id": "VCFv4.5.tex::The VCF specification::p16",
          "quote": "A: The field has one value per alternate allele.\n  The values must be in the same order as listed in the ALT column (described in section data-lines).\n   R: The field has one value for each possible allele, including the reference.\n  The order of the values must be the reference allele first, then the alternate alleles as listed in the ALT column.",
          "rule_severity": "CRITICAL",
          "section_id": "The VCF specification"
        },
        {
          "chunk_id": "VCFv4.5.tex::Information field format::p157",
          "quote": "* A: The field has one value per alternate allele.\n  The values must be in the same order as listed in the ALT column (described in section <ref>).",
          "rule_severity": "CRITICAL",
          "section_id": "Information field format"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
    {
      "mr_id": "0258c3e904f0",
      "mr_name": "Fileformat must be first line",
      "scope": "VCF.header",
      "preconditions": [
        "has_two_meta_lines"
      ],
      "transform_steps": [
        "violate_fileformat_first_line"
      ],
      "oracle": "error_consensus",
      "evidence": [
        {
          "chunk_id": "VCFv4.5.tex::File format::p154",
          "quote": "A single `fileformat' line is always required, must be the first line in the file, and details the VCF format version number.",
          "rule_severity": "CRITICAL",
          "section_id": "File format"
        },
        {
          "chunk_id": "VCFv4.5.tex::Changes between VCFv4.2 and VCFv4.3::p1691",
          "quote": "Meta-information lines can be in any order, with the exception of ##fileformat which must come first.",
          "rule_severity": "CRITICAL",
          "section_id": "Changes between VCFv4.2 and VCFv4.3"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
