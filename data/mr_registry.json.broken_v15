      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p54",
          "quote": "All optional fields follow the TAG:TYPE:VALUE format where TAG is a two-character string that matches /[A-Za-z][A-Za-z0-9]/.",
          "rule_severity": "ADVISORY",
          "section_id": "The SAM Format Specification"
        }
      ],
      "ambiguity_flags": [
        "The spec defines the TAG:TYPE:VALUE format but the exact set of valid TYPE characters is defined in the separate SAMtags specification"
      ],
      "query_methods": []
    },
    {
      "mr_id": "db1f4df6b38f",
      "mr_name": "Hard-soft clipping equivalence invariance",
      "scope": "SAM.record",
      "preconditions": [
        "has_cigar",
        "has_seq",
        "seed has at least one alignment with hard clipping (H) or soft clipping (S) CIGAR operations"
      ],
      "transform_steps": [
        "toggle_cigar_hard_soft_clipping"
      ],
      "oracle": "Converting H<->S clipping preserves the underlying alignment semantics: the mapped portion of the read (non-clipped bases) and the reference coordinates remain unchanged. When H→S, dummy bases are padded in SEQ/QUAL; when S→H, those bases are trimmed. The total query-consuming length of non-clipping ops (M, I, =, X) stays the same.",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::Recommended Practice for the SAM Format::p134",
          "quote": "[SAM v1 — Recommended Practice for the SAM Format] * Adjacent CIGAR operations should be different.",
          "rule_severity": "ADVISORY",
          "section_id": "Recommended Practice for the SAM Format"
        }
      ],
      "ambiguity_flags": [
        "The spec does not explicitly define H↔S equivalence; this is a normalization convention from tools like samtools calmd and bcftools norm"
      ],
      "query_methods": []
    },
    {
      "mr_id": "0f61b7b3a065",
      "mr_name": "BAM round-trip normalization invariance",
      "scope": "SAM.record",
      "preconditions": [
        "samtools_available",
        "has_cigar",
        "has_seq"
      ],
      "transform_steps": [
        "sam_bam_round_trip"
      ],
      "oracle": "Transiting SAM through BAM encoding and back preserves all alignment data: the 11 mandatory fields, all optional tags, and the header remain semantically identical. CIGAR normalization (e.g., merging adjacent identical ops) may occur during BAM encoding/decoding but the biological interpretation is invariant.",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::Recommended Practice for the SAM Format::p134",
          "quote": "[SAM v1 — Recommended Practice for the SAM Format] * Adjacent CIGAR operations should be different.",
          "rule_severity": "ADVISORY",
          "section_id": "Recommended Practice for the SAM Format"
        }
      ],
      "ambiguity_flags": [
        "BAM has a 16-bit n_cigar_op limit (65535 ops); extremely long CIGARs may be truncated or stored in CG tag, which could cause minor differences"
      ],
      "query_methods": []
    },
