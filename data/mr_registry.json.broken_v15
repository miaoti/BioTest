      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The alignment section: mandatory fields::p118",
          "quote": "POS: 1-based leftmost mapping POSition of the first CIGAR operation that ``consumes'' a reference base (see table below). The first base in a reference sequence has coordinate 1.",
          "rule_severity": "CRITICAL",
          "section_id": "The alignment section: mandatory fields"
        }
      ],
      "ambiguity_flags": [
        "CRAM may collapse =/X to M, which changes CIGAR representation but not the reference coordinate span"
      ],
      "query_methods": []
    },
