    {
      "mr_id": "7690cdb23c3e",
      "mr_name": "CIGAR split/merge equivalence under split_or_merge_adjacent_cigar_ops",
      "scope": "SAM.record",
      "preconditions": [
        "has_cigar"
      ],
      "transform_steps": [
        "split_or_merge_adjacent_cigar_ops"
      ],
      "oracle": "P(parse(x)) == P(parse(T(x))) where P normalizes by merging adjacent identical CIGAR operations; total query-consumed length (M/I/S/=X) is preserved",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::Recommended Practice for the SAM Format::p134",
          "quote": "Adjacent CIGAR operations should be different.",
          "rule_severity": "ADVISORY",
          "section_id": "Recommended Practice for the SAM Format"
        },
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p53",
          "quote": "If not a `*', the length of the sequence must equal the sum of lengths of MIS=X operations in CIGAR.",
          "rule_severity": "CRITICAL",
          "section_id": "The SAM Format Specification"
        }
      ],
      "ambiguity_flags": [
        "The spec says adjacent CIGAR operations 'should' be different (advisory, not mandatory); splitting/merging preserves the total consumed length but may produce adjacent identical ops which some tools may warn about"
      ],
      "query_methods": []
    },
    {
      "mr_id": "99d69275e18a",
      "mr_name": "Flag bit exclusivity violation detection under violate_flag_bit_exclusivity",
      "scope": "SAM.record",
      "preconditions": [
        "has_mapped_read"
      ],
      "transform_steps": [
        "violate_flag_bit_exclusivity"
      ],
      "oracle": "parse(x) succeeds but parse(T(x)) MUST raise an error or return a record with flag 0x4 set and RNAME/POS reset to */0, per SAMv1 §1.4.1",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p47",
          "quote": "Bit 0x4 is the only reliable place to tell whether the read is unmapped. If 0x4 is set, no assumptions can be made about RNAME, POS, CIGAR, MAPQ, and bits 0x2, 0x100, and 0x800.",
          "rule_severity": "CRITICAL",
          "section_id": "The SAM Format Specification"
        }
      ],
      "ambiguity_flags": [
        "The spec says 'no assumptions can be made' when 0x4 is set, but does not explicitly say parsers must reject the inconsistency; some parsers may silently accept it"
      ],
      "query_methods": []
    },
    {
      "mr_id": "fb51ee08fb7d",
      "mr_name": "Optional tag type violation detection under violate_optional_tag_type_character",
      "scope": "SAM.record",
      "preconditions": [
        "has_optional_tag"
      ],
      "transform_steps": [
        "violate_optional_tag_type_character"
      ],
