  "enforced": [
    {
      "mr_id": "319f95e31472",
      "mr_name": "CIGAR/SEQ length mismatch violation detection under violate_cigar_seq_length",
      "scope": "SAM.record",
      "preconditions": [
        "has_cigar",
        "has_seq"
      ],
      "transform_steps": [
        "violate_cigar_seq_length"
      ],
      "oracle": "parse(x) succeeds but parse(T(x)) MUST raise an error because SEQ length no longer equals sum of M/I/S/=X CIGAR operations",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p53",
          "quote": "If not a `*', the length of the sequence must equal the sum of lengths of MIS=X operations in CIGAR.",
          "rule_severity": "CRITICAL",
          "section_id": "The SAM Format Specification"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
    {
      "mr_id": "705c9755b48c",
      "mr_name": "TLEN sign consistency violation rejection",
      "scope": "SAM.record",
      "preconditions": [
        "has_nonzero_tlen"
      ],
      "transform_steps": [
        "violate_tlen_sign_consistency"
      ],
      "oracle": "A spec-compliant parser MUST reject a SAM record where the TLEN sign is inconsistent with the paired-end template rule (both ends having the same sign when they must have opposite signs). The error-consensus oracle checks that all SUTs vote REJECT or CRASH; any ACCEPT or SILENT_SKIP is a conformance bug.",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::The SAM Format Specification::p50",
          "quote": "The TLEN field is positive for the leftmost segment of the template, negative for the rightmost, and the sign for any middle segment is undefined. If segments cover the same coordinates then the choice of which is leftmost and rightmost is arbitrary, but the two ends must still have differing signs.",
          "rule_severity": "CRITICAL",
          "section_id": "The SAM Format Specification"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": []
    },
    {
      "mr_id": "ce4ded5e9811",
      "mr_name": "Optional tag field permutation preserves query method results",
      "scope": "SAM.record",
      "preconditions": [
        "has_optional_tag"
      ],
      "transform_steps": [
        "permute_optional_tag_fields",
        "query_method_roundtrip"
      ],
      "oracle": "P(parse(x)) == P(parse(T(x))) for each listed query method — permuting the order of optional TAG:TYPE:VALUE fields (columns 12+) is semantics-preserving per SAM spec, so all parsed record properties must remain identical",
      "evidence": [
        {
          "chunk_id": "SAMv1.tex::SAM Version History::p326",
          "quote": "Clarify that header field tags must be distinct within each line, and that the ordering of both header fields and alignment optional fields is not significant.",
          "rule_severity": "CRITICAL",
          "section_id": "SAM Version History"
        }
      ],
      "ambiguity_flags": [],
      "query_methods": [
        "length",
        "aligned",
        "shape",
        "target"
      ]
    },
